# Copia este archivo a .env.local y rellena los valores.
# .env.local está en .gitignore y no se sube al repo.

# Firebase (ya los tienes)
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# ...

# Firebase Admin (obligatorio para: confirmar pagos Stripe, webhook, stock, emails de pedido)
# Opción A: JSON en una línea
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
# Opción B (Vercel): mismo JSON en Base64, una sola línea
# FIREBASE_SERVICE_ACCOUNT_KEY_BASE64=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Email (elige UNO o fuerza con EMAIL_PROVIDER) ---
# Orden automático si EMAIL_PROVIDER=auto o vacío: Resend → MailerSend → SMTP
# EMAIL_PROVIDER=resend | mailersend | smtp | auto

# Opción A — Resend (recomendado si MailerSend trial te limita destinatarios)
# https://resend.com — verifica dominio o usa su remite de prueba hasta verificar
RESEND_API_KEY=re_...

# Opción B — MailerSend
MAILERSEND_API_KEY=mlsn_...
# MAILERSEND_API_URL=https://api.mailersend.com/v1/email

# Opción C — SMTP (ej. Gmail con “contraseña de aplicación”; Wix no da SMTP útil para Vercel)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tu@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# EMAIL_PROVIDER=smtp
# Con Gmail, EMAIL_FROM suele ir mejor como el mismo Gmail: "Nombre <tu@gmail.com>"

# Remitente visible (dominio verificado en Resend/MailerSend; con SMTP suele ser la misma cuenta)
# EMAIL_FROM=AmarusDesign <noreply@tudominio.com>

# NEXT_PUBLIC_ADMIN_EMAIL=amarusdesign2014@gmail.com
# ADMIN_NOTIFY_EMAIL=amarusdesign2014@gmail.com

# --- Supabase Storage (imágenes y vídeos del admin) ---
# Dashboard: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Solo servidor (API routes, migración). Nunca exponer en el cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Bucket público (por defecto "images")
# NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=images

# Cloudinary (opcional, solo URLs legacy hasta migrar con npm run migrate:storage)
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# CLOUDINARY_URL=cloudinary://key:secret@cloud_name
