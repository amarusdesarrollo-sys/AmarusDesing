# Copia este archivo a .env.local y rellena los valores.
# .env.local está en .gitignore y no se sube al repo.

# Firebase (ya los tienes)
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# ...

# Firebase Admin (obligatorio para: confirmar pagos Stripe, webhook, stock, emails de pedido)
# Opción A: JSON en una línea
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
# Opción B (Vercel): mismo JSON en Base64, una sola línea
# FIREBASE_SERVICE_ACCOUNT_KEY_BASE64=

# Stripe — añade estas variables a .env.local
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend — emails de pedido (confirmación al cliente + aviso al admin)
RESEND_API_KEY=re_...
# Opcional: dominio verificado (ej: pedidos@tudominio.com). Sin esto, usa onboarding@resend.dev
# EMAIL_FROM=pedidos@amarusdesign.com
# Opcional: mismo email que admin pero definido en Vercel (sobrescribe el default de auth-admin.ts)
# NEXT_PUBLIC_ADMIN_EMAIL=amarusdesign2014@gmail.com
# Opcional: email donde recibir aviso de nuevo pedido y formulario contacto. Por defecto = ADMIN_EMAIL
# ADMIN_NOTIFY_EMAIL=amarusdesign2014@gmail.com
